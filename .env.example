# ============================================================================
# vooi-mm-bot configuration
# Copy to `.env` and fill in. Every variable can also be set via shell env;
# values in `.env` take precedence.
# ============================================================================

# --- VOOI API ---------------------------------------------------------------
# Bearer token for the VOOI Perps API (https://perps-api.vooi.io).
BEARER_TOKEN=
# API base URL. Override only if you use a non-production deployment.
# BASE_URL=https://perps-api.vooi.io

# --- Strategy legs ----------------------------------------------------------
# PRIMARY leg: passive BUY+SELL limit orders around mid price (earns the spread).
# HEDGE leg:   market order on the opposite side once the primary fills.
#
# PRIMARY_EXCHANGE / HEDGE_EXCHANGE accept (case-insensitive):
#
#   API exchanges:                aster | extended | hyperliquid | lighter
#     (the authoritative list is whatever GET /exchange/markets returns for
#      your account — run `bun run markets` to see yours)
#
#   Builder venues on Hyperliquid (HIP-3 deployers, resolved to prefixed markets):
#     kinetic | kinetiq | km      → hyperliquid `km:*` markets   (Kinetiq)
#     tradexyz | xyz | trade.xyz  → hyperliquid `xyz:*` markets  (trade.xyz)
#
#   Generic builder syntax:       hyperliquid:<prefix>
#     works for any deployer without a code change, e.g. hyperliquid:km.
#     `bun run markets` lists every prefix your account can see.
PRIMARY_EXCHANGE=extended
HEDGE_EXCHANGE=kinetic

# Cross-exchange asset alias. The bot finds the market whose baseSymbol equals
# the alias or ends with `:<alias>` (HIP-3 builder markets, e.g. `xyz:SPCX`).
# To discover symbols/aliases: `bun run markets <fragment>` (e.g. `bun run markets spcx`).
ALIAS=SPCX

# Per-leg overrides when the alias is missing/ambiguous on an exchange.
# Values come from GET /exchange/markets (`baseSymbol` and `id` fields) —
# `bun run markets <fragment>` prints both.
# PRIMARY_SYMBOL=          # exact baseSymbol on the primary venue, e.g. SPCX-USD
# PRIMARY_MARKET_ID=       # exact market id, disambiguates duplicate symbols (e.g. BTCUSDT on aster)
# HEDGE_SYMBOL=            # e.g. xyz:SPCX
# HEDGE_MARKET_ID=

# Target leverage per leg. Unset = market's maxLeverage (capped by MAX_LEVERAGE_CAP).
# PRIMARY_LEVERAGE=5
# HEDGE_LEVERAGE=5
# MAX_LEVERAGE_CAP=100

# --- Quoting ----------------------------------------------------------------
# Half-spread for the passive limit orders, as a fraction (0.001 = 0.1%).
SPREAD_PERCENT=0.001
# Fraction of available margin used to size each cycle (both legs).
BALANCE_RATIO=0.85
# Skip cycles whose order notional would be below this floor (USD).
MIN_ORDER_NOTIONAL_USD=5
# Margin preflight: require available >= notional/leverage * this buffer.
# MARGIN_PREFLIGHT_BUFFER=1.12

# --- Timeouts ----------------------------------------------------------------
# How long to wait for the primary limit to fill before restarting the cycle (ms).
# FILL_TIMEOUT_MS=120000
# How long to wait for the close limits before force-closing both legs (ms).
# CLOSE_TIMEOUT_MS=30000

# --- Volume pacing (all optional, unset = disabled) ---------------------------
# Max sum of `2 * size` traded per rolling window, in base units.
# MAX_TRADED_BASE_PER_WINDOW=10
# Rolling window length (ms). Default 1 hour.
# VOLUME_PACE_WINDOW_MS=3600000
# Max `2 * size` per cycle, in base units.
# MAX_CYCLE_TRADED_BASE=1
# Pause between cycles (ms).
# MIN_CYCLE_GAP_MS=0

# --- Broker attribution (optional) --------------------------------------------
# Defaults to VOOI's public broker/builder ids per exchange. Override or disable:
# BROKER_HYPERLIQUID_ID=0x...
# BROKER_HYPERLIQUID_FEE_BPS=15
# BROKER_LIGHTER_ID=132230
# BROKER_LIGHTER_FEE_BPS=150
# BROKER_ASTER_ID=0x...
# BROKER_ASTER_FEE_BPS=1.5
# Set an empty id to send orders without broker attribution:
# BROKER_EXTENDED_ID=

# --- Logging -------------------------------------------------------------------
# Append-only log file next to the project root.
# BOT_LOG=bot.log
# Set to 0 to stop mirroring logs to the terminal (file only).
# BOT_LOG_MIRROR=1
# JSONL dump of full request/response on API errors.
# API_ERROR_DEBUG_LOG=api-error-debug.jsonl
